DEEPSEEK_API_KEY=
FAL_KEY=

# Legacy single-site keys (kept for backward compatibility in tooling).
WP_USER=
WP_KEY=
WP_URL=https://example.com

# Multi-blog scoped WordPress credentials used by the app publish/category flow.
WP_URL_THE_WEEKEND_FOLIO=https://example.com
WP_USER_THE_WEEKEND_FOLIO=
WP_KEY_THE_WEEKEND_FOLIO=

WP_URL_YOUR_MIDNIGHT_DESK=https://example.com
WP_USER_YOUR_MIDNIGHT_DESK=
WP_KEY_YOUR_MIDNIGHT_DESK=

WP_URL_THE_SUNDAY_PATIO=https://example.com
WP_USER_THE_SUNDAY_PATIO=
WP_KEY_THE_SUNDAY_PATIO=

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ARTICLE_ATTEMPTS=5
DEEPSEEK_INITIAL_TEMPERATURE=0.6
DEEPSEEK_RETRY_TEMPERATURE=0.2
FAL_MODEL=fal-ai/flux/dev
FAL_MODEL_PIN=fal-ai/flux/dev
WP_POST_STATUS=draft
WP_TIMEZONE=UTC
WP_ENABLE_INDEXING=0
WP_DEFAULT_COMMENT_STATUS=open
WP_BASE_PAGES=about,contact,privacy-policy
WP_SEO_PLUGIN=seo-by-rank-math
WP_USE_WPCLI=1
WP_DELETE_DEFAULT_PLUGINS=1
PINCLICKS_APP_BASE_URL=https://app.pinclicks.com
PINCLICKS_TOP_PINS_URL_TEMPLATE=https://app.pinclicks.com/top-pins?query={keyword}
PINCLICKS_USERNAME=
PINCLICKS_PASSWORD=
PINCLICKS_STORAGE_STATE_PATH=
PINTEREST_TRENDS_BASE_URL=https://trends.pinterest.com
PINTEREST_TRENDS_FILTER_REGION=GLOBAL
PINTEREST_TRENDS_FILTER_RANGE=12m
PINTEREST_TRENDS_EXPORT_DOWNLOAD_DIR=
PINTEREST_TRENDS_TOP_KEYWORDS=20
PINTEREST_PINCLICKS_WINNERS_PER_RUN=5
PINTEREST_TRENDS_FORCE_INCLUDE_KEYWORD=1
PINTEREST_USERNAME=
PINTEREST_PASSWORD=
PINTEREST_STORAGE_STATE_PATH=
PINTEREST_TRENDS_QUERY_URL_TEMPLATE=
PINTEREST_ANALYSIS_PROVIDER=deepseek
PINTEREST_ANALYSIS_MODEL=deepseek-chat
PINTEREST_ANALYSIS_ATTEMPTS=3
ARTICLE_VALIDATOR_REPAIR_PROMPT=
PINTEREST_SEED_MAP_JSON={}
PINTEREST_BOARD_MAP_JSON={"THE_WEEKEND_FOLIO":{"default":"Weekend Lifestyle Ideas","overrides":{"travel":"Weekend Travel","home":"Weekend Home"}},"THE_SUNDAY_PATIO":{"default":"Patio Inspiration","overrides":{"furniture":"Patio Furniture Ideas","lighting":"Outdoor Lighting Ideas"}}}
# Recommended for readable overlays: map each blog suffix (or `default`) to a valid scalable font path.
# Windows example: {"default":"C:\\\\Windows\\\\Fonts\\\\segoeui.ttf"}
# macOS example: {"default":"/System/Library/Fonts/Supplemental/Arial.ttf"}
# Linux example: {"default":"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"}
PINTEREST_FONT_MAP_JSON={}
# Pin visual template mode:
# - center_strip: branded center strip with pin title + blog name
# - none: no text template
PINTEREST_PIN_TEMPLATE_MODE=center_strip
# Failure behavior when center-strip text rendering fails:
# - template_or_none: fall back to no-text full-bleed image
# - fail: raise image generation error
PINTEREST_PIN_TEMPLATE_FAILURE_POLICY=template_or_none
PINTEREST_CSV_PATH_TEMPLATE=artifacts/exports/pinterest_bulk_upload_{blog_suffix}.csv
PINTEREST_CSV_CADENCE_MINUTES=240
# Optional permalink override per blog suffix:
# WP_PUBLIC_POST_URL_TEMPLATE_THE_SUNDAY_PATIO={site_url}/{slug}/
