# ============================================================
# Publishing Service — Production Environment Variables
# ============================================================
# Copy to .env and fill in your values before running docker compose up.

# --- PostgreSQL ---
POSTGRES_USER=publishing
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# --- Ports (optional) ---
PORT=80

# --- CORS (optional — defaults work for Docker) ---
# CORS_ORIGINS=["https://yourdomain.com"]
