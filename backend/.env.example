# Publishing Service Backend - Environment Configuration
# Copy this file to .env and fill in the values.

# Application
DEBUG=true

# Database (async SQLAlchemy connection string)
# Local dev: SQLite.  For production use a postgresql+asyncpg:// URL.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Fernet encryption key for credential storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Redis (required for Celery task queue in production)
REDIS_URL=redis://localhost:6379/0

# --- Docker Compose overrides (used by docker-compose.yml) ---
# API_PORT=8000
# DB_PORT=5432
# REDIS_PORT=6379
